async function doPush() {
  const urlEl = document.getElementById("sync-url-input");
  const url = urlEl ? urlEl.value.trim() : state.syncUrl;
  saveSyncUrl(url);
  if (!url) { state._syncStatus = { type: "err", text: "Pega primero la URL de la Web App." }; render(); focusSyncInput(); return; }
  state._syncStatus = { type: "", text: "Subiendo..." };
  render(); focusSyncInput();
  try {
    const res = await fetch(url, {
      method: "POST",
      headers: { "Content-Type": "text/plain;charset=utf-8" },
      body: JSON.stringify({ clients: state.clients }),
    });
    const data = await res.json();
    if (data.ok) {
      state._syncStatus = { type: "ok", text: `Subido correctamente (${data.clientes} clientes).` };
    } else {
      state._syncStatus = { type: "err", text: "Error: " + (data.error || "desconocido") };
    }
  } catch (err) {
    state._syncStatus = { type: "err", text: "No se pudo conectar. Revisa la URL y que la app esté implementada como 'Cualquier usuario'." };
  }
  render(); focusSyncInput();
}

async function doPull() {
  const urlEl = document.getElementById("sync-url-input");
  const url = urlEl ? urlEl.value.trim() : state.syncUrl;
  saveSyncUrl(url);
  if (!url) { state._syncStatus = { type: "err", text: "Pega primero la URL de la Web App." }; render(); focusSyncInput(); return; }
  state._syncStatus = { type: "", text: "Descargando..." };
  render(); focusSyncInput();
  try {
    const res = await fetch(url, { method: "GET" });
    const data = await res.json();
    if (data.clients) {
      state.clients = data.clients;
      save();
      state._syncStatus = { type: "ok", text: `Descargados ${data.clients.length} clientes.` };
    } else {
      state._syncStatus = { type: "err", text: "Error: " + (data.error || "no se recibieron datos") };
    }
  } catch (err) {
    state._syncStatus = { type: "err", text: "No se pudo conectar. Revisa la URL." };
  }
  render(); focusSyncInput();
}

