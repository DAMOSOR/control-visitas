/* ---------------- State ---------------- */
let state = {
  clients: [],
  tab: "clientes",
  search: "",
  provinceFilter: "Todas",
  sortBy: "dias",
  selectedId: null,
  showFilters: false,
  showVisitModal: false,
  showClientForm: false,
  editingClient: null,
  showSyncModal: false,
  syncUrl: "",
  _syncStatus: null,
  _syncSyncing: false,
};

const SYNC_URL_KEY = "sync-url";
function loadSyncUrl() { try { state.syncUrl = localStorage.getItem(SYNC_URL_KEY) || ""; } catch (e) {} }
function saveSyncUrl(url) { state.syncUrl = url; try { localStorage.setItem(SYNC_URL_KEY, url); } catch (e) {} }

function load() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    state.clients = raw ? JSON.parse(raw) : seedClients();
  } catch (e) { state.clients = seedClients(); }
}
function save() {
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state.clients)); } catch (e) {}
}

/* ---------------- Derived data ---------------- */
function getFiltered() {
  let list = state.clients.filter(c =>
    c.name.toLowerCase().includes(state.search.toLowerCase()) ||
    c.city.toLowerCase().includes(state.search.toLowerCase())
  );
  if (state.provinceFilter !== "Todas") list = list.filter(c => c.province === state.provinceFilter);
  list = list.map(c => { const last = lastVisitOf(c); return { ...c, _days: last ? daysSince(last.date) : Infinity, _status: statusOf(c) }; });
  if (state.sortBy === "dias") list.sort((a,b) => b._days - a._days);
  else if (state.sortBy === "nombre") list.sort((a,b) => a.name.localeCompare(b.name));
  else if (state.sortBy === "categoria") list.sort((a,b) => a.category.localeCompare(b.category));
  return list;
}
function getStats() {
  const today = new Date(); today.setHours(0,0,0,0);
  const weekStart = new Date(today); weekStart.setDate(today.getDate() - today.getDay());
  const monthStart = new Date(today.getFullYear(), today.getMonth(), 1);
  let t=0, w=0, m=0;
  state.clients.forEach(c => (c.visits||[]).forEach(v => {
    const vd = new Date(v.date);
    if (vd >= today) t++;
    if (vd >= weekStart) w++;
    if (vd >= monthStart) m++;
  }));
  const withStatus = state.clients.map(c => ({ ...c, _status: statusOf(c), _last: lastVisitOf(c) }));
  const pending = withStatus.filter(c => c._status === "amber").length;
  const overdue = withStatus.filter(c => c._status === "red").length;
  const mostVisited = [...state.clients].sort((a,b) => (b.visits?.length||0)-(a.visits?.length||0)).slice(0,5);
  const forgotten = [...withStatus].sort((a,b) => {
    const da = a._last ? daysSince(a._last.date) : 99999;
    const db = b._last ? daysSince(b._last.date) : 99999;
    return db - da;
  }).slice(0,5);
  return { today:t, week:w, month:m, pending, overdue, mostVisited, forgotten };
}

/* ---------------- Rendering ---------------- */
function render() {
  const app = document.getElementById("app");
  const selected = state.clients.find(c => c.id === state.selectedId) || null;
  let html = "";

  if (selected) {
    html += renderDetail(selected);
  } else if (state.tab === "clientes") {
    html += renderList();
    html += renderBottomNav();
  } else {
    html += renderDashboard();
    html += renderBottomNav();
  }

  if (state.showVisitModal && selected) html += renderVisitModal(selected);
  if (state.showClientForm) html += renderClientForm(state.editingClient);
  if (state.showSyncModal) html += renderSyncModal();

  app.innerHTML = html;
  attachHandlers();
}

