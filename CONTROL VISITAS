function daysAgoISO(n) { const d = new Date(); d.setDate(d.getDate() - n); return d.toISOString(); }
function daysSince(iso) { return Math.floor((Date.now() - new Date(iso).getTime()) / 86400000); }
function lastVisitOf(c) { if (!c.visits || !c.visits.length) return null; return [...c.visits].sort((a,b)=>new Date(b.date)-new Date(a.date))[0]; }
function statusOf(c) { const last = lastVisitOf(c); if (!last) return "red"; const d = daysSince(last.date); if (d <= c.frequency) return "green"; if (d <= c.frequency*1.5) return "amber"; return "red"; }
function fmtDate(iso) { return new Date(iso).toLocaleDateString("es-ES",{day:"2-digit",month:"2-digit",year:"2-digit"}); }
function fmtTime(iso) { return new Date(iso).toLocaleTimeString("es-ES",{hour:"2-digit",minute:"2-digit"}); }
function esc(s) { return (s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }

