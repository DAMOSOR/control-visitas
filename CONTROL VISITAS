function attachHandlers() {
  const app = document.getElementById("app");

  const searchInput = document.getElementById("search-input");
  if (searchInput) {
    searchInput.addEventListener("input", (e) => {
      state.search = e.target.value;
      const cursor = e.target.selectionStart;
      render();
      const again = document.getElementById("search-input");
      if (again) { again.focus(); again.setSelectionRange(cursor, cursor); }
    });
  }

  app.addEventListener("click", onAppClick);
}

function onAppClick(e) {
  const el = e.target.closest("[data-action]");
  if (!el) return;
  const action = el.dataset.action;
  const id = el.dataset.id;
  const value = el.dataset.value;

  switch (action) {
    case "open-client": state.selectedId = id; render(); break;
    case "back": state.selectedId = null; render(); break;
    case "set-tab": state.tab = value; state.selectedId = null; render(); break;
    case "toggle-filters": state.showFilters = !state.showFilters; render(); break;
    case "set-province": state.provinceFilter = value; render(); break;
    case "set-sort": state.sortBy = value; render(); break;
    case "new-client": state.editingClient = null; state.showClientForm = true; render(); break;
    case "edit-client": {
      const c = state.clients.find(x => x.id === id);
      state.editingClient = c; state.showClientForm = true; render(); break;
    }
    case "close-client-form": state.showClientForm = false; state.editingClient = null; render(); break;
    case "open-sync-modal": state.showSyncModal = true; state._syncStatus = null; render(); focusSyncInput(); break;
    case "close-sync-modal": state.showSyncModal = false; render(); break;
    case "sync-push": doPush(); break;
    case "sync-pull": doPull(); break;
    case "open-visit-modal": state.showVisitModal = true; state._visitType = "Visita"; state._visitNotes = ""; render(); break;
    case "close-visit-modal": state.showVisitModal = false; render(); break;
    case "set-visit-type": state._visitType = value; render(); break;
    case "save-visit": {
      const notesEl = document.getElementById("visit-notes");
      const notes = notesEl ? notesEl.value : "";
      const c = state.clients.find(x => x.id === id);
      if (c) {
        c.visits = c.visits || [];
        c.visits.push({ id: uid(), date: new Date().toISOString(), type: state._visitType || "Visita", notes });
        save();
      }
      state.showVisitModal = false;
      render();
      break;
    }
    case "save-client": {
      const data = {
        name: document.getElementById("f-name").value.trim(),
        city: document.getElementById("f-city").value.trim(),
        province: document.getElementById("f-province").value,
        address: document.getElementById("f-address").value.trim(),
        contact: document.getElementById("f-contact").value.trim(),
        phone: document.getElementById("f-phone").value.trim(),
        email: document.getElementById("f-email").value.trim(),
        frequency: Number(document.getElementById("f-frequency").value),
        category: document.getElementById("f-category").value,
        status: "Activo",
      };
      if (!data.name) break;
      if (id) {
        const c = state.clients.find(x => x.id === id);
        Object.assign(c, data);
      } else {
        state.clients.push({ ...data, id: uid(), visits: [] });
      }
      save();
      state.showClientForm = false; state.editingClient = null;
      render();
      break;
    }
  }

  if (action === "close-visit-modal" || action === "close-client-form") {
    // already handled above
  }
}

